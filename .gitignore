# Backups created by install.sh
*.bak

# Generated per-user files (never committed)
home/.config/git/delta.config
home/.config/git/local.config
home/.config/zsh/local.zsh

# ── Secrets & credentials — NEVER commit (this repo is PUBLIC) ────
# Backstopped by gitleaks (.pre-commit-config.yaml) for anything these
# filename patterns can't catch. Per-user secrets belong in the untracked
# local overlays above, never in the tracked tree.
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
**/id_rsa
**/id_dsa
**/id_ecdsa
**/id_ed25519
**/*_rsa
**/*_ed25519
**/.netrc
**/.credentials.json
**/credentials
**/hosts.yml
**/auth.json

# ── Personal runtime state / history — NEVER commit ──────────────
**/.claude.json
**/.claude/projects/
**/.claude/history.jsonl
**/.claude/.credentials.json
